{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "FedRAMP Baseline - Hardened Public Web Subnet Firewall Stack",
  "Resources": {
    "PublicWebNACL": {
      "Type": "AWS::EC2::NetworkAcl",
      "Properties": {
        "VpcId": { "Fn::ImportValue": "SandboxVPC-ID" },
        "Tags": [
          { "Key": "Name", "Value": "Sandbox-PublicWeb-NACL" }
        ]
      }
    },
    "AllowHTTPSInbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PublicWebNACL" },
        "RuleNumber": 100,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": false,
        "CidrBlock": "0.0.0.0/0",
        "PortRange": { "From": 443, "To": 443 }
      }
    },
    "AllowHTTPInbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PublicWebNACL" },
        "RuleNumber": 110,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": false,
        "CidrBlock": "0.0.0.0/0",
        "PortRange": { "From": 80, "To": 80 }
      }
    },
    "AllowEphemeralInbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PublicWebNACL" },
        "RuleNumber": 120,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": false,
        "CidrBlock": "0.0.0.0/0",
        "PortRange": { "From": 1024, "To": 65535 }
      }
    },
    "ExplicitDenyAllInbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PublicWebNACL" },
        "RuleNumber": 200,
        "Protocol": -1,
        "RuleAction": "deny",
        "Egress": false,
        "CidrBlock": "0.0.0.0/0"
      }
    },
    "AllowEphemeralOutbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PublicWebNACL" },
        "RuleNumber": 100,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": true,
        "CidrBlock": "0.0.0.0/0",
        "PortRange": { "From": 1024, "To": 65535 }
      }
    },
    "ExplicitDenyAllOutbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PublicWebNACL" },
        "RuleNumber": 200,
        "Protocol": -1,
        "RuleAction": "deny",
        "Egress": true,
        "CidrBlock": "0.0.0.0/0"
      }
    },
    "PublicWebAssociation": {
      "Type": "AWS::EC2::SubnetNetworkAclAssociation",
      "Properties": {
        "NetworkAclId": { "Ref": "PublicWebNACL" },
        "SubnetId": { "Fn::ImportValue": "PublicWebSubnet-ID" }
      }
    },
    "PublicWebAssociationAZ2": {
      "Type": "AWS::EC2::SubnetNetworkAclAssociation",
      "Properties": {
        "NetworkAclId": { "Ref": "PublicWebNACL" },
        "SubnetId": { "Fn::ImportValue": "PublicWebSubnetAZ2-ID" }
      }
    }
  }
}