{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "FedRAMP Baseline - Hardened Least-Privilege Private App Subnet Firewall Stack",
  "Resources": {
    "PrivateAppNACL": {
      "Type": "AWS::EC2::NetworkAcl",
      "Properties": {
        "VpcId": { "Fn::ImportValue": "SandboxVPC-ID" },
        "Tags": [
          { "Key": "Name", "Value": "Sandbox-PrivateApp-NACL" }
        ]
      }
    },
    "AllowOnlyWebTierInbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateAppNACL" },
        "RuleNumber": 100,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": false,
        "CidrBlock": "10.0.1.0/28",
        "PortRange": { "From": 8080, "To": 8080 }
      }
    },
    "AllowWebTierAZ2Inbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateAppNACL" },
        "RuleNumber": 110,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": false,
        "CidrBlock": "10.0.1.16/28",
        "PortRange": { "From": 8080, "To": 8080 }
      }
    },
    "AllowEphemeralInboundFromNAT": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateAppNACL" },
        "RuleNumber": 120,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": false,
        "CidrBlock": "0.0.0.0/0",
        "PortRange": { "From": 1024, "To": 65535 }
      }
    },
    "ExplicitDenyAllInbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateAppNACL" },
        "RuleNumber": 200,
        "Protocol": -1,
        "RuleAction": "deny",
        "Egress": false,
        "CidrBlock": "0.0.0.0/0"
      }
    },
    "AllowEphemeralOutboundToWeb": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateAppNACL" },
        "RuleNumber": 100,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": true,
        "CidrBlock": "10.0.1.0/28",
        "PortRange": { "From": 1024, "To": 65535 }
      }
    },
    "AllowEphemeralOutboundToWebAZ2": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateAppNACL" },
        "RuleNumber": 110,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": true,
        "CidrBlock": "10.0.1.16/28",
        "PortRange": { "From": 1024, "To": 65535 }
      }
    },
    "AllowHTTPSOutboundToNAT": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateAppNACL" },
        "RuleNumber": 120,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": true,
        "CidrBlock": "0.0.0.0/0",
        "PortRange": { "From": 443, "To": 443 }
      }
    },
    "ExplicitDenyAllOutbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateAppNACL" },
        "RuleNumber": 200,
        "Protocol": -1,
        "RuleAction": "deny",
        "Egress": true,
        "CidrBlock": "0.0.0.0/0"
      }
    },
    "PrivateAppAssociation": {
      "Type": "AWS::EC2::SubnetNetworkAclAssociation",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateAppNACL" },
        "SubnetId": { "Fn::ImportValue": "PrivateAppSubnet-ID" }
      }
    }
  }
}