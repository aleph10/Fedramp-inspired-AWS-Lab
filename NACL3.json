{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "FedRAMP Baseline - Air-Gapped Database Subnet Firewall Stack",
  "Resources": {
    "PrivateDBNACL": {
      "Type": "AWS::EC2::NetworkAcl",
      "Properties": {
        "VpcId": { "Fn::ImportValue": "SandboxVPC-ID" },
        "Tags": [
          { "Key": "Name", "Value": "Sandbox-PrivateDB-NACL" }
        ]
      }
    },
    "AllowOnlyAppTierInbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateDBNACL" },
        "RuleNumber": 100,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": false,
        "CidrBlock": "10.0.2.0/28",
        "PortRange": { "From": 3306, "To": 3306 }
      }
    },
    "ExplicitDenyAllInbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateDBNACL" },
        "RuleNumber": 200,
        "Protocol": -1,
        "RuleAction": "deny",
        "Egress": false,
        "CidrBlock": "0.0.0.0/0"
      }
    },
    "AllowEphemeralOutboundToApp": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateDBNACL" },
        "RuleNumber": 100,
        "Protocol": 6,
        "RuleAction": "allow",
        "Egress": true,
        "CidrBlock": "10.0.2.0/28",
        "PortRange": { "From": 1024, "To": 65535 }
      }
    },
    "ExplicitDenyAllOutbound": {
      "Type": "AWS::EC2::NetworkAclEntry",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateDBNACL" },
        "RuleNumber": 200,
        "Protocol": -1,
        "RuleAction": "deny",
        "Egress": true,
        "CidrBlock": "0.0.0.0/0"
      }
    },
    "PrivateDBAssociation": {
      "Type": "AWS::EC2::SubnetNetworkAclAssociation",
      "Properties": {
        "NetworkAclId": { "Ref": "PrivateDBNACL" },
        "SubnetId": { "Fn::ImportValue": "PrivateDBSubnet-ID" }
      }
    }
  }
}